{
  "name": "yugioh-card-maker",
  "version": "1.0.0",
  "private": true,
  "main": "src/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "webpack serve --mode development",
    "dev:electron": "node scripts/wait-for-dev-server.js && cross-env NODE_ENV=development electronmon .",
    "build:renderer": "cross-env NODE_ENV=production webpack --mode production",
    "build": "npm run build:renderer && electron-builder",
    "download:ygo-art": "node scripts/download-ygo-canvas-art.js",
    "download:ygo-thumbs": "node scripts/download-ygo-thumbs.js",
    "postinstall": "electron-builder install-app-deps",
    "lint:js": "eslint --ext \".js,.vue\" --ignore-path .gitignore .",
    "lint": "npm run lint:js"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.5.1",
    "@fortawesome/free-brands-svg-icons": "^6.5.1",
    "@fortawesome/free-regular-svg-icons": "^6.5.1",
    "@fortawesome/free-solid-svg-icons": "^6.5.1",
    "@fortawesome/vue-fontawesome": "^2.0.10",
    "better-sqlite3": "^11.0.0",
    "bootstrap": "^4.6.0",
    "bootstrap-vue": "^2.23.1",
    "core-js": "^3.15.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.1",
    "jszip": "^3.10.1",
    "sharp": "^0.33.5",
    "vue": "^2.7.16",
    "vuex": "^3.6.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/eslint-parser": "^7.14.7",
    "@babel/preset-env": "^7.24.0",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^12.0.2",
    "cross-env": "^7.0.3",
    "css-loader": "^6.10.0",
    "electron": "^28.2.0",
    "electron-builder": "^24.13.3",
    "electronmon": "^2.0.2",
    "eslint": "^7.29.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-vue": "^7.12.1",
    "html-webpack-plugin": "^5.6.0",
    "prettier": "^2.3.2",
    "style-loader": "^3.3.4",
    "vue-loader": "^15.11.1",
    "vue-template-compiler": "^2.7.16",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.2"
  }
}
